<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{% block title %}{{ title }} — Eruption Forecast Report{% endblock %}</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
  <style>
    /* ── Reset & Base ──────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:        #0d1117;
      --ink-light:  #4a5568;
      --accent:     #1a3a5c;
      --accent-2:   #2c5282;
      --rule:       #d1dae6;
      --surface:    #ffffff;
      --surface-2:  #f7f9fc;
      --surface-3:  #edf2f7;
      --highlight:  #ebf4ff;
      --badge-bg:   #dbeafe;
      --badge-ink:  #1e40af;
      --success:    #166534;
      --font-body:  'Georgia', 'Times New Roman', serif;
      --font-mono:  'Menlo', 'Consolas', 'Courier New', monospace;
      --font-sans:  -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      --max-w:      860px;
      --sidebar-w:  220px;
    }

    html { font-size: 15px; -webkit-font-smoothing: antialiased; }

    body {
      font-family: var(--font-body);
      color: var(--ink);
      background: var(--surface);
      line-height: 1.7;
    }

    /* ── Layout ────────────────────────────────────────────────────────── */
    .layout {
      display: flex;
      min-height: 100vh;
    }

    /* ── Sidebar ───────────────────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      min-width: var(--sidebar-w);
      background: var(--surface-2);
      border-right: 1px solid var(--rule);
      padding: 2rem 0;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      flex-shrink: 0;
    }

    .sidebar-brand {
      padding: 0 1.25rem 1.5rem;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 1rem;
    }

    .sidebar-brand-label {
      font-family: var(--font-sans);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink-light);
    }

    .sidebar-brand-title {
      font-family: var(--font-sans);
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--accent);
      margin-top: 0.2rem;
      line-height: 1.3;
    }

    .sidebar-nav { list-style: none; }

    .sidebar-nav-section {
      font-family: var(--font-sans);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-light);
      padding: 0.9rem 1.25rem 0.25rem;
    }

    .sidebar-nav a {
      display: block;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      color: var(--ink-light);
      text-decoration: none;
      padding: 0.35rem 1.25rem;
      border-left: 2px solid transparent;
      transition: color 0.15s, border-color 0.15s, background 0.15s;
    }

    .sidebar-nav a:hover,
    .sidebar-nav a.active {
      color: var(--accent);
      border-left-color: var(--accent);
      background: var(--highlight);
    }

    /* ── Main content ──────────────────────────────────────────────────── */
    .main {
      flex: 1;
      min-width: 0;
      padding: 3rem 3.5rem 4rem;
    }

    .main-inner {
      width: 100%;
    }

    /* ── Report header ─────────────────────────────────────────────────── */
    .report-header {
      padding-bottom: 2rem;
      margin-bottom: 2.5rem;
      border-bottom: 2px solid var(--accent);
    }

    .report-header-eyebrow {
      font-family: var(--font-sans);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-2);
      margin-bottom: 0.5rem;
    }

    .report-title {
      font-family: var(--font-sans);
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.25;
      letter-spacing: -0.02em;
    }

    .report-meta {
      font-family: var(--font-sans);
      font-size: 0.78rem;
      color: var(--ink-light);
      margin-top: 0.75rem;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    /* ── Sections ──────────────────────────────────────────────────────── */
    .section {
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 4px;
      padding: 1.75rem 2rem;
      margin-bottom: 2rem;
    }

    .section-title {
      font-family: var(--font-sans);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.25rem;
      padding-bottom: 0.6rem;
      border-bottom: 1px solid var(--rule);
    }

    h2 {
      font-family: var(--font-sans);
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--ink);
      margin: 2rem 0 0.9rem;
      letter-spacing: -0.01em;
    }

    h3 {
      font-family: var(--font-sans);
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--accent);
      margin: 1.5rem 0 0.7rem;
    }

    p {
      margin-bottom: 0.9rem;
      color: var(--ink-light);
      font-size: 0.92rem;
    }

    /* ── Tables ────────────────────────────────────────────────────────── */
    .metadata-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-sans);
      font-size: 0.8rem;
    }

    .metadata-table tr {
      border-bottom: 1px solid var(--surface-3);
    }

    .metadata-table td:first-child {
      font-weight: 600;
      color: var(--ink-light);
      width: 38%;
      padding: 0.45rem 1rem 0.45rem 0;
      vertical-align: top;
      white-space: nowrap;
    }

    .metadata-table td:last-child {
      color: var(--ink);
      padding: 0.45rem 0;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }

    .stats-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-sans);
      font-size: 0.8rem;
      margin-top: 0.5rem;
    }

    .stats-table thead tr {
      background: var(--accent);
      color: white;
    }

    .stats-table thead th {
      padding: 0.55rem 0.85rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.72rem;
      letter-spacing: 0.05em;
      white-space: nowrap;
    }

    .stats-table tbody tr:nth-child(even) {
      background: var(--surface-2);
    }

    .stats-table tbody tr:hover {
      background: var(--highlight);
    }

    .stats-table tbody td {
      padding: 0.5rem 0.85rem;
      border-bottom: 1px solid var(--rule);
      color: var(--ink);
    }

    .stats-table tfoot tr {
      background: var(--surface-3);
      font-weight: 600;
    }

    .stats-table tfoot td {
      padding: 0.5rem 0.85rem;
      border-top: 2px solid var(--rule);
      color: var(--ink);
      font-family: var(--font-sans);
      font-size: 0.8rem;
    }

    .highlight-row {
      background: var(--highlight) !important;
      font-weight: 600;
    }

    .highlight-row td { color: var(--accent) !important; }

    /* ── Badges ────────────────────────────────────────────────────────── */
    .badge {
      display: inline-block;
      background: var(--badge-bg);
      color: var(--badge-ink);
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 600;
      padding: 0.15rem 0.5rem;
      border-radius: 3px;
      white-space: nowrap;
    }

    .badge-success {
      background: #dcfce7;
      color: var(--success);
    }

    .badge-warn {
      background: #fef3c7;
      color: #92400e;
    }

    /* ── Details / summary ─────────────────────────────────────────────── */
    details {
      border: 1px solid var(--rule);
      border-radius: 4px;
      margin-bottom: 0.75rem;
      overflow: hidden;
    }

    summary {
      font-family: var(--font-sans);
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--accent);
      padding: 0.65rem 1rem;
      cursor: pointer;
      background: var(--surface-2);
      list-style: none;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    summary::before {
      content: '▶';
      font-size: 0.6rem;
      transition: transform 0.2s;
      color: var(--ink-light);
    }

    details[open] summary::before { transform: rotate(90deg); }

    details > .details-body { padding: 1rem; }

    /* ── Plot containers ───────────────────────────────────────────────── */
    .plot-container {
      margin: 1rem 0;
      border-radius: 4px;
      overflow: hidden;
      background: var(--surface);
    }

    /* ── Grid ──────────────────────────────────────────────────────────── */
    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    /* ── Footer ────────────────────────────────────────────────────────── */
    .report-footer {
      margin-top: 4rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--rule);
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: var(--font-sans);
      font-size: 0.72rem;
      color: var(--ink-light);
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .report-footer strong { color: var(--accent); }

    /* ── Print ─────────────────────────────────────────────────────────── */
    @media print {
      .sidebar { display: none; }
      .main { padding: 1.5cm 2cm; }
      .section { break-inside: avoid; }
      .plot-container { break-inside: avoid; }
      a { text-decoration: none; color: inherit; }
    }

    /* ── Responsive ────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .layout { flex-direction: column; }
      .sidebar {
        width: 100%;
        height: auto;
        position: static;
        border-right: none;
        border-bottom: 1px solid var(--rule);
      }
      .main { padding: 1.5rem; }
      .grid-2 { grid-template-columns: 1fr; }
    }
  </style>
  {% block extra_head %}{% endblock %}
</head>
<body>
<div class="layout">

  {# ── Sidebar ────────────────────────────────────────────────────────── #}
  {% block sidebar %}
  {% if sections %}
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="sidebar-brand-label">Eruption Forecast</div>
      <div class="sidebar-brand-title">Pipeline Report</div>
    </div>
    <ul class="sidebar-nav">
      {% for sec in sections %}
        {% if sec.type == 'header' %}
          <li class="sidebar-nav-section">{{ sec.label }}</li>
        {% else %}
          <li><a href="#{{ sec.anchor }}">{{ sec.label }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
  </aside>
  {% endif %}
  {% endblock %}

  {# ── Main ────────────────────────────────────────────────────────────── #}
  <main class="main">
    <div class="main-inner">

      {# Report header #}
      <header class="report-header">
        <div class="report-header-eyebrow">Eruption Forecast — Analysis Report</div>
        <h1 class="report-title">{% block title_body %}{{ title }}{% endblock %}</h1>
        <div class="report-meta">
          {% block meta_section %}
          <span>Generated: <strong>{{ generated_at }}</strong></span>
          <span>Package: <strong>eruption-forecast v{{ version }}</strong></span>
          {% endblock %}
        </div>
      </header>

      {# Page content #}
      {% block content %}{% endblock %}

      {# Footer #}
      <footer class="report-footer">
        <span>eruption-forecast <strong>v{{ version }}</strong></span>
        <span>Generated {{ generated_at }}</span>
      </footer>

    </div>
  </main>

</div>
{% block extra_scripts %}{% endblock %}
</body>
</html>
