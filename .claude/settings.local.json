{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git push:*)",
      "Bash(python -m py_compile:*)",
      "Bash(python:*)",
      "Bash(uv:*)",
      "Bash(git checkout:*)",
      "Bash(dir:*)",
      "Bash(git commit:*)",
      "Bash(find:*)",
      "Bash(git pull:*)",
      "Bash(gh pr create:*)",
      "Bash(gh auth:*)",
      "Bash(gh repo list:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(test:*)",
      "Bash(uvx ty check:*)"
    ],
    "deny": [
      "Read(*.log)",
      "Read(*.csv)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.ipynb)",
      "Read(./.uv_cache/**)",
      "Read(./.venv/**)",
      "Read(./output/**)",
      "Read(./logs/**)",
      "Edit(*.log)",
      "Edit(*.csv)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*.ipynb)",
      "Edit(./.uv_cache/**)",
      "Edit(./.venv/**)",
      "Edit(./output/**)",
      "Edit(./logs/**)"
    ]
  }
}
